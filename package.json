{
  "name": "kyrei-agent-desktop",
  "version": "0.5.2",
  "private": true,
  "description": "Kyrei — cross-platform AI coding agent desktop app",
  "desktopName": "kyrei.desktop",
  "homepage": "https://github.com/dizzzable/Kyrei",
  "repository": {
    "type": "git",
    "url": "https://github.com/dizzzable/Kyrei.git"
  },
  "bugs": {
    "url": "https://github.com/dizzzable/Kyrei/issues"
  },
  "author": {
    "name": "dizzzable",
    "email": "dizzzable@users.noreply.github.com"
  },
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "main": "electron/main.js",
  "scripts": {
    "dev:renderer": "vite",
    "build": "vite build",
    "build:engine": "node scripts/build-engine.mjs",
    "gen-icons": "node scripts/gen-icons.mjs",
    "typecheck:engine": "tsc --noEmit -p core/engine/tsconfig.json",
    "typecheck:renderer": "tsc --noEmit -p tsconfig.json",
    "check:js": "node scripts/check-js.mjs",
    "check:i18n": "node scripts/check-i18n.mjs",
    "pretest": "npm run build:engine",
    "test": "vitest --run",
    "gate": "npm run typecheck:engine && npm run typecheck:renderer && npm run check:js && npm run check:i18n && npm run test",
    "start": "vite build && node scripts/build-engine.mjs && electron .",
    "package:prepare": "npm run gen-icons && vite build && node scripts/build-engine.mjs",
    "dist": "npm run package:prepare && electron-builder",
    "dist:win": "npm run package:prepare && electron-builder --win",
    "dist:mac": "npm run package:prepare && electron-builder --mac",
    "dist:mac:x64": "npm run package:prepare && electron-builder --mac --x64",
    "dist:mac:arm64": "npm run package:prepare && electron-builder --mac --arm64",
    "dist:linux": "npm run package:prepare && electron-builder --linux",
    "dist:linux:x64": "npm run package:prepare && electron-builder --linux AppImage deb pacman --x64",
    "dist:linux:arm64": "npm run package:prepare && electron-builder --linux AppImage deb --arm64",
    "dist:arch": "npm run package:prepare && electron-builder --linux pacman --x64"
  },
  "dependencies": {
    "@ai-sdk/amazon-bedrock": "5.0.20",
    "@ai-sdk/anthropic": "4.0.14",
    "@ai-sdk/google": "4.0.14",
    "@ai-sdk/google-vertex": "5.0.18",
    "@ai-sdk/openai": "4.0.13",
    "@ai-sdk/openai-compatible": "3.0.9",
    "@electric-sql/pglite": "0.5.4",
    "@electric-sql/pglite-pgvector": "0.0.5",
    "@electric-sql/pglite-socket": "0.2.7",
    "@vscode/ripgrep": "^1.18.0",
    "ai": "7.0.26",
    "better-sqlite3": "^12.11.1",
    "class-variance-authority": "^0.7.1",
    "electron-updater": "^6.8.9",
    "fast-glob": "^3.3.3",
    "gpt-tokenizer": "3.4.0",
    "hast-util-from-html-isomorphic": "^2.0.0",
    "hast-util-to-text": "^4.0.2",
    "katex": "^0.17.0",
    "pg": "^8.22.0",
    "radix-ui": "^1.6.2",
    "remark-math": "^6.0.0",
    "sqlite-vec": "^0.1.9",
    "unist-util-visit-parents": "^6.0.2",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@resvg/resvg-js": "^2.6.2",
    "@tailwindcss/vite": "^4.1.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/katex": "^0.16.8",
    "@types/node": "^26.1.1",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^6.0.3",
    "clsx": "^2.1.1",
    "electron": "^43.1.0",
    "electron-builder": "^26.15.3",
    "esbuild": "^0.28.1",
    "fast-check": "^4.9.0",
    "lucide-react": "^1.24.0",
    "msw": "^2.15.0",
    "png-to-ico": "^3.0.2",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.0",
    "shiki": "^4.3.1",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.1.0",
    "typescript": "^7.0.2",
    "vite": "^8.1.4",
    "vitest": "^4.1.10"
  },
  "build": {
    "afterPack": "./scripts/after-pack.mjs",
    "toolsets": {
      "appimage": "1.0.3"
    },
    "appId": "com.kyrei.agent",
    "productName": "Kyrei",
    "publish": [
      {
        "provider": "github",
        "owner": "dizzzable",
        "repo": "Kyrei"
      }
    ],
    "files": [
      "electron/**/*",
      "core/**/*",
      "!core/engine/**/*.ts",
      "!core/engine/**/*.test.ts",
      "core/engine/.dist/**/*",
      "dist/renderer/**/*",
      "assets/icon.png",
      "assets/icon.ico",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "LICENSE",
        "to": "LICENSE.txt"
      },
      {
        "from": "THIRD_PARTY_NOTICES.md",
        "to": "THIRD_PARTY_NOTICES.md"
      },
      {
        "from": "assets/fonts/OFL.txt",
        "to": "THIRD_PARTY_LICENSES/JetBrainsMono-OFL.txt"
      }
    ],
    "asarUnpack": [
      "**/node_modules/better-sqlite3/**",
      "**/node_modules/sqlite-vec*/**",
      "**/node_modules/@electric-sql/pglite/**",
      "**/node_modules/@electric-sql/pglite-pgvector/**",
      "**/node_modules/bindings/**",
      "**/node_modules/@vscode/ripgrep/**"
    ],
    "directories": {
      "output": "dist/app",
      "buildResources": "build"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.ico",
      "artifactName": "${productName}-${version}-${arch}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowElevation": true,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "assets/icon.ico",
      "uninstallerIcon": "assets/icon.ico",
      "installerHeaderIcon": "assets/icon.ico",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Kyrei",
      "artifactName": "${productName}-Setup-${version}.${ext}"
    },
    "portable": {
      "artifactName": "${productName}-Portable-${version}.${ext}"
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "icon": "assets/icon.png",
      "artifactName": "${productName}-${version}-${arch}.${ext}"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb",
        "pacman"
      ],
      "icon": "assets/icon.png",
      "executableName": "kyrei",
      "syncDesktopName": true,
      "category": "Development",
      "synopsis": "Local AI coding agent desktop",
      "artifactName": "${productName}-${version}-${arch}.${ext}"
    },
    "appImage": {
      "executableArgs": []
    },
    "deb": {
      "depends": [
        "libgtk-3-0",
        "libnotify4",
        "libnss3",
        "libxss1",
        "libxtst6",
        "xdg-utils",
        "libatspi2.0-0",
        "libuuid1",
        "libsecret-1-0",
        "gnome-keyring"
      ],
      "recommends": [
        "libsecret-tools"
      ]
    },
    "pacman": {
      "artifactName": "${productName}-${version}-${arch}.pkg.tar.zst",
      "depends": [
        "alsa-lib",
        "at-spi2-core",
        "dbus",
        "gtk3",
        "libnotify",
        "libsecret",
        "gnome-keyring",
        "libxkbcommon",
        "libxss",
        "libxtst",
        "nss",
        "xdg-utils"
      ],
      "fpm": [
        "--pacman-optional-depends=kwallet: KDE Plasma KWallet Secret Service (alternative to gnome-keyring)",
        "--pacman-optional-depends=keepassxc: alternative Secret Service provider when desktop keyring is unavailable",
        "--pacman-optional-depends=xorg-xwayland: XWayland fallback for Electron on pure Wayland if native Ozone fails"
      ]
    }
  }
}
