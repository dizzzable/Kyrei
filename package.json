{
  "name": "kyrei-agent-desktop",
  "version": "0.2.0",
  "private": true,
  "description": "Kyrei — cross-platform AI coding agent desktop app",
  "author": {
    "name": "dizzzable",
    "email": "dizzable.23@gmail.com"
  },
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "main": "electron/main.js",
  "scripts": {
    "dev:renderer": "vite",
    "build": "vite build",
    "build:engine": "node scripts/build-engine.mjs",
    "gen-icons": "node scripts/gen-icons.mjs",
    "typecheck:engine": "tsc --noEmit -p core/engine/tsconfig.json",
    "typecheck:renderer": "tsc --noEmit -p tsconfig.json",
    "check:js": "node scripts/check-js.mjs",
    "check:i18n": "node scripts/check-i18n.mjs",
    "test": "vitest --run",
    "gate": "npm run typecheck:engine && npm run typecheck:renderer && npm run build:engine && npm run check:js && npm run check:i18n && npm run test",
    "start": "vite build && node scripts/build-engine.mjs && electron .",
    "package:prepare": "npm run gen-icons && vite build && node scripts/build-engine.mjs",
    "dist": "npm run package:prepare && electron-builder",
    "dist:win": "npm run package:prepare && electron-builder --win",
    "dist:mac": "npm run package:prepare && electron-builder --mac",
    "dist:linux": "npm run package:prepare && electron-builder --linux"
  },
  "dependencies": {
    "@ai-sdk/amazon-bedrock": "5.0.17",
    "@ai-sdk/anthropic": "4.0.12",
    "@ai-sdk/google": "4.0.12",
    "@ai-sdk/google-vertex": "5.0.16",
    "@ai-sdk/openai": "4.0.11",
    "@ai-sdk/openai-compatible": "3.0.7",
    "@vscode/ripgrep": "^1.18.0",
    "ai": "7.0.22",
    "better-sqlite3": "^12.11.1",
    "class-variance-authority": "^0.7.1",
    "fast-glob": "^3.3.3",
    "gpt-tokenizer": "3.4.0",
    "hast-util-from-html-isomorphic": "^2.0.0",
    "hast-util-to-text": "^4.0.2",
    "katex": "^0.17.0",
    "radix-ui": "^1.6.2",
    "remark-math": "^6.0.0",
    "sqlite-vec": "^0.1.9",
    "unist-util-visit-parents": "^6.0.2",
    "zod": "3.25.76"
  },
  "devDependencies": {
    "@resvg/resvg-js": "^2.6.2",
    "@tailwindcss/vite": "^4.1.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/katex": "^0.16.8",
    "@types/node": "^26.1.1",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^6.0.3",
    "clsx": "^2.1.1",
    "electron": "^43.1.0",
    "electron-builder": "^26.15.3",
    "esbuild": "^0.28.1",
    "fast-check": "^4.9.0",
    "lucide-react": "^1.24.0",
    "msw": "^2.15.0",
    "png-to-ico": "^3.0.2",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.0",
    "shiki": "^4.3.1",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.1.0",
    "typescript": "^7.0.2",
    "vite": "^8.1.4",
    "vitest": "^4.1.10"
  },
  "build": {
    "appId": "com.kyrei.agent",
    "productName": "Kyrei",
    "files": [
      "electron/**/*",
      "core/**/*",
      "!core/engine/**/*.ts",
      "!core/engine/**/*.test.ts",
      "core/engine/.dist/**/*",
      "dist/renderer/**/*",
      "assets/icon.png",
      "assets/icon.ico",
      "package.json"
    ],
    "asarUnpack": [
      "**/node_modules/better-sqlite3/**",
      "**/node_modules/sqlite-vec*/**",
      "**/node_modules/bindings/**",
      "**/node_modules/@vscode/ripgrep/**"
    ],
    "directories": {
      "output": "dist/app",
      "buildResources": "build"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.ico",
      "artifactName": "${productName}-${version}-${arch}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowElevation": true,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Kyrei",
      "artifactName": "${productName}-Setup-${version}.${ext}"
    },
    "portable": {
      "artifactName": "${productName}-Portable-${version}.${ext}"
    },
    "mac": {
      "target": ["dmg", "zip"],
      "icon": "assets/icon.png"
    },
    "linux": {
      "target": ["AppImage", "deb"],
      "icon": "assets/icon.png"
    }
  }
}
